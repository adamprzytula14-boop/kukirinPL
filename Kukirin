<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>KukirinPL | Encyklopedia</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@400;700&display=swap" rel="stylesheet">

<style>

:root{
--p:#ff4500;
--bg:#0b0b0b;
--card:#151515;
--txt:#fff;
--acc:#00eaff;
}

*{box-sizing:border-box;margin:0;padding:0}

body{
background:var(--bg);
color:var(--txt);
font-family:Rajdhani;
}

nav{
position:fixed;
top:0;
width:100%;
background:black;
padding:15px 40px;
display:flex;
justify-content:space-between;
border-bottom:2px solid var(--p);
z-index:10;
}

.logo{
font-family:Orbitron;
font-size:22px;
}

.logo span{color:var(--p)}

.container{
padding:110px 40px 40px;
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:25px;
}

.card{
background:var(--card);
border-radius:12px;
padding:20px;
border:1px solid #222;
display:flex;
flex-direction:column;
}

.card img{
width:100%;
border-radius:8px;
margin-bottom:10px;
}

.title{
font-family:Orbitron;
font-size:20px;
}

.badge{
background:var(--p);
font-size:11px;
padding:3px 8px;
margin:6px 0;
display:inline-block;
}

.specs{
display:grid;
grid-template-columns:1fr 1fr;
gap:8px;
margin:10px 0;
}

.specs span{
color:var(--acc);
font-weight:700;
}

.price{
font-size:22px;
font-family:Orbitron;
color:var(--acc);
margin:10px 0;
}

.buttons{
display:flex;
gap:6px;
}

button{
flex:1;
padding:9px;
border:none;
font-family:Orbitron;
font-size:11px;
border-radius:6px;
cursor:pointer;
}

.shop{background:var(--acc);color:black}
.info{background:var(--p);color:white}

.search{
margin:90px auto 10px;
width:300px;
display:block;
padding:10px;
border-radius:6px;
border:none;
background:#111;
color:white;
}

.calc{
width:90%;
max-width:700px;
margin:20px auto;
background:#111;
padding:20px;
border:1px solid #333;
border-radius:10px;
}

.calc h3{
font-family:Orbitron;
margin-bottom:10px;
color:var(--acc);
}

.calc-row{
display:flex;
gap:10px;
flex-wrap:wrap;
}

.calc input,.calc select{
flex:1;
padding:10px;
border:none;
background:#222;
color:white;
border-radius:5px;
}

.result{
margin-top:15px;
font-size:28px;
font-family:Orbitron;
color:var(--acc);
}

.modal{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.85);
display:none;
justify-content:center;
align-items:center;
}

.modal-box{
background:#111;
padding:30px;
width:400px;
border:2px solid var(--p);
border-radius:10px;
}

.modal h2{
font-family:Orbitron;
margin-bottom:10px;
}

.close{
margin-top:20px;
background:var(--p);
width:100%;
}

</style>
</head>

<body>

<nav>
<div class="logo">KUKIRIN<span>PL</span></div>
</nav>

<input class="search" placeholder="Szukaj modelu..." oninput="searchModel(this.value)">

<div class="calc">

<h3>Kalkulator realnego zasięgu</h3>

<div class="calc-row">

<select id="model"></select>

<input type="number" id="weight" value="80" placeholder="Waga (kg)">

<select id="style">
<option value="0.8">Eko</option>
<option value="1" selected>Normalny</option>
<option value="1.3">Sport</option>
</select>

</div>

<div class="result" id="rangeResult">0 km</div>

</div>

<div class="container" id="grid"></div>

<div class="modal" id="modal">
<div class="modal-box" id="modalContent"></div>
</div>

<script>

const models=[

{
name:"KuKurin G2",
tag:"Classic",
img:"https://i.imgur.com/lJp8Q5C.png",
power:"800W",
batteryV:48,
batteryAh:15,
speed:"45km/h",
range:55,
price:"2999 zł",
charge:"7h",
wheels:"10 cali",
shop:"https://geekbuying.com"
},

{
name:"KuKurin G2 Pro",
tag:"Bestseller",
img:"https://i.imgur.com/vc6Y6CE.png",
power:"1000W",
batteryV:48,
batteryAh:15.6,
speed:"50km/h",
range:55,
price:"3499 zł",
charge:"8h",
wheels:"10 cali",
shop:"https://geekbuying.com"
},

{
name:"KuKurin G2 Master",
tag:"Dual Motor",
img:"https://i.imgur.com/G0x5D2H.png",
power:"2x1000W",
batteryV:52,
batteryAh:20.8,
speed:"60km/h",
range:70,
price:"4799 zł",
charge:"9h",
wheels:"10 cali",
shop:"https://geekbuying.com"
},

{
name:"KuKurin G3",
tag:"Design",
img:"https://i.imgur.com/X2LZ4qQ.png",
power:"1200W",
batteryV:52,
batteryAh:18,
speed:"50km/h",
range:70,
price:"4199 zł",
charge:"8h",
wheels:"10 cali",
shop:"https://geekbuying.com"
},

{
name:"KuKurin G4",
tag:"Offroad",
img:"https://i.imgur.com/UV6Bt4f.png",
power:"2000W",
batteryV:60,
batteryAh:20,
speed:"70km/h",
range:75,
price:"5499 zł",
charge:"10h",
wheels:"11 cali",
shop:"https://geekbuying.com"
}

]

const grid=document.getElementById("grid")
const select=document.getElementById("model")

function render(list){

grid.innerHTML=list.map(m=>`

<div class="card">

<img src="${m.img}">

<div class="title">${m.name}</div>

<div class="badge">${m.tag}</div>

<div class="specs">

<div>Moc <span>${m.power}</span></div>
<div>V-max <span>${m.speed}</span></div>
<div>Koła <span>${m.wheels}</span></div>
<div>Ładowanie <span>${m.charge}</span></div>

</div>

<div class="price">${m.price}</div>

<div class="buttons">

<button class="shop" onclick="window.open('${m.shop}')">
SKLEP
</button>

<button class="info" onclick="showInfo('${m.name}')">
INFO
</button>

</div>

</div>

`).join("")
}

function showInfo(name){

const m=models.find(x=>x.name===name)

document.getElementById("modal").style.display="flex"

document.getElementById("modalContent").innerHTML=`

<h2>${m.name}</h2>

<p>Moc: ${m.power}</p>
<p>Bateria: ${m.batteryV}V ${m.batteryAh}Ah</p>
<p>Zasięg producenta: ${m.range} km</p>
<p>Prędkość: ${m.speed}</p>
<p>Koła: ${m.wheels}</p>
<p>Czas ładowania: ${m.charge}</p>

<button class="close" onclick="closeModal()">ZAMKNIJ</button>

`

}

function closeModal(){
document.getElementById("modal").style.display="none"
}

function searchModel(q){

q=q.toLowerCase()

const filtered=models.filter(m=>m.name.toLowerCase().includes(q))

render(filtered)

}

function populateSelect(){

select.innerHTML=models.map(m=>`<option value="${m.name}">${m.name}</option>`).join("")

}

function calculate(){

const name=select.value
const weight=parseFloat(document.getElementById("weight").value)
const style=parseFloat(document.getElementById("style").value)

const m=models.find(x=>x.name===name)

const wh=m.batteryV*m.batteryAh
const weightFactor=weight/75

let range=wh/(15*weightFactor*style)

if(range>m.range)range=m.range

document.getElementById("rangeResult").innerText=Math.round(range)+" km"

}

document.getElementById("weight").addEventListener("input",calculate)
document.getElementById("style").addEventListener("change",calculate)
select.addEventListener("change",calculate)

render(models)
populateSelect()
calculate()

</script>

</body>
</html>
